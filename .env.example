# Google Cloud service account used by /api/submit-trip.js to write
# Plan My Trip submissions into a Google Sheet.
#
# Set these as Environment Variables in your Vercel project settings
# (Project -> Settings -> Environment Variables). Never commit real
# values to this file or anywhere in git.

# The "client_email" field from the service account JSON key.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The "private_key" field from the service account JSON key.
# Keep the \n escape sequences exactly as they appear in the JSON file,
# and wrap the whole value in quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=
