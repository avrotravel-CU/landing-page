# /api/submit-trip.js forwards each Plan My Trip submission to a Google
# Apps Script Web App that's bound to your destination Google Sheet
# (created via Extensions -> Apps Script inside the Sheet itself, no
# Google Cloud project or service account needed).
#
# Set this as an Environment Variable in your Vercel project settings
# (Project -> Settings -> Environment Variables). Never commit the real
# value to this file or anywhere in git — treat the URL as a secret,
# since anyone who has it can submit rows to your sheet.

# The "Web app URL" you get after deploying the Apps Script
# (Deploy -> New deployment -> Web app). Looks like:
# https://script.google.com/macros/s/AKfycb.../exec
GOOGLE_APPS_SCRIPT_URL=

# A long random string that must match the SHARED_SECRET script property
# you set inside the Apps Script project (Project Settings -> Script
# Properties). The deployment has to allow "Anyone" access so this
# server-to-server call is accepted, but the script rejects any request
# that doesn't include this secret, so it isn't really open to the public.
# Generate one with: openssl rand -hex 32
GOOGLE_APPS_SCRIPT_SECRET=
